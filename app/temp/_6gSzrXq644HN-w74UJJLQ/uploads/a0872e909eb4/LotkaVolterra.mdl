{UTF-8}
Conejos= INTEG (
	Nac Conejos-Muert Conejos,
		100 )
	~	conejos
	~		|

Lobos= INTEG (
	Nac Lobos-Muert Lobos,
		25)
	~	lobos
	~		|

Muert Conejos=
	Conejos*Lobos*Tasa muert Conejos
	~	conejos/Day
	~		|

Muert Lobos=
	Lobos*Tasa muert Lobos
	~	lobos/Day
	~		|

Nac Conejos=
	Conejos*Tasa nac Conejos
	~	conejos/Day
	~		|

Nac Lobos=
	Conejos*Lobos*Tasa nac Lobos
	~	lobos/Day
	~		|

Tasa muert Conejos=
	0.0025
	~	1/(lobos*Day)
	~		|

Tasa muert Lobos=
	0.04
	~	1/Day
	~		|

Tasa nac Conejos=
	0.01
	~	1/Day
	~		|

Tasa nac Lobos=
	0.002
	~	1/(conejos * Day)
	~		|

********************************************************
	.Control
********************************************************~
		Simulation Control Parameters
	|

FINAL TIME  = 10000
	~	Day
	~	The final time for the simulation.
	|

INITIAL TIME  = 0
	~	Day
	~	The initial time for the simulation.
	|

SAVEPER  = 
        TIME STEP
	~	Day [0,?]
	~	The frequency with which output is stored.
	|

TIME STEP  = 0.001
	~	Day [0,?]
	~	The time step for the simulation.
	|

